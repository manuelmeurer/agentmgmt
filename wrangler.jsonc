{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentmgmt",
  "compatibility_date": "2025-11-05",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "agentmgmt.dev",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
