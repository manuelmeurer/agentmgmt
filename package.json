{
  "name": "agentmgmt",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "npm run build && concurrently -k -n build,wrangler -c blue,magenta \"chokidar 'src/**/*' -c 'npm run build'\" \"wrangler dev\"",
    "deploy": "npm run build && wrangler deploy",
    "update-stars": "node scripts/update-stars.mjs"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.1.0",
    "js-yaml": "^4.2.0",
    "wrangler": "^4.90.0"
  }
}
